@app.route('/api/tools/run', methods=['POST'])
def run_tool():
    """Executes the integrated scripts provided by the user."""
    if not is_admin():
        return jsonify({"error": "Admin privileges required"}), 403
        
    data = request.json
    script_alias = data.get('script')
    
    script_map = {
        "hardening": ("Privacy Hardening Script.py", "python"),
        "optimizer": ("ROG_BE92_Signal_Optimizer.py", "python"),
        "firewall_rules": ("secure_gaming_firewall.ps1", "powershell"),
        "net_reset": ("network optimizer with reset.bat", "cmd")
    }
    
    if script_alias not in script_map:
        return jsonify({"error": "Unknown script alias"}), 400
        
    filename, runner = script_map[script_alias]
    filepath = os.path.join(SCRIPTS_DIR, filename)
    
    if not os.path.exists(filepath):
        return jsonify({"error": f"File not found: {filepath}"}), 404
        
    try:
        if runner == "python":
            subprocess.Popen([sys.executable, filepath], creationflags=subprocess.CREATE_NEW_CONSOLE)
        elif runner == "powershell":
            subprocess.Popen(["powershell", "-ExecutionPolicy", "Bypass", "-File", filepath], creationflags=subprocess.CREATE_NEW_CONSOLE)
        elif runner == "cmd":
            subprocess.Popen([filepath], creationflags=subprocess.CREATE_NEW_CONSOLE)
            
        return jsonify({"status": "success", "message": f"Launched {filename}"})
    except Exception as e:
        return jsonify({"error": str(e)}), 500

